---
import { SignIn } from '../components/SignIn';
import BaseLayout from '../layouts/BaseLayout.astro';

const requestedRedirect = Astro.url.searchParams.get('redirect');
const redirectPath = requestedRedirect?.startsWith('/') && !requestedRedirect.startsWith('//')
  ? requestedRedirect
  : '/account';
---

<BaseLayout title="Sign In" description="Sign in to your Podex account">
  <main class="min-h-screen bg-background">
    <section class="border-b border-border-subtle bg-surface/30">
      <div class="container py-12 md:py-16">
        <p class="font-mono text-xs uppercase tracking-[0.24em] text-accent">Account</p>
        <h1 class="mt-3 text-4xl">Sign in to Podex</h1>
        <p class="mt-3 max-w-lg text-text-secondary">
          Receive a short-lived sign-in link by email. No password required.
        </p>
      </div>
    </section>
    <div class="container py-10">
      <div class="max-w-md rounded-lg border border-border-subtle bg-surface p-6">
        <SignIn client:load redirectPath={redirectPath} />
      </div>
    </div>
  </main>
</BaseLayout>
