---
import AccountNavigation from '../../components/AccountNavigation.astro';
import { AccountSettings } from '../../components/AccountSettings';
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Account Settings" description="Manage your Podex account preferences">
  <main class="min-h-screen bg-background">
    <section class="border-b border-border-subtle bg-surface/30">
      <div class="container py-10 md:py-14">
        <p class="font-mono text-xs uppercase tracking-[0.24em] text-accent">Account</p>
        <h1 class="mt-3 text-4xl">Settings</h1>
        <p class="mt-3 text-text-secondary">Control email delivery for activity you follow.</p>
      </div>
    </section>
    <AccountNavigation active="settings" />
    <div class="container py-10">
      <div class="max-w-2xl">
        <AccountSettings client:load />
      </div>
    </div>
  </main>
</BaseLayout>
