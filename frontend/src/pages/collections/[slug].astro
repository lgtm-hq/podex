---
import MediaCard from '../../components/MediaCard.astro';
import StatePanel from '../../components/StatePanel.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from '../../lib/api';
import type { EditorialCollectionDetail } from '../../lib/types';

const { slug } = Astro.params;
let collection: EditorialCollectionDetail | null = null;
let error: unknown = null;

if (slug) {
  try {
    collection = await getCollection(slug);
  } catch (cause) {
    console.error('Failed to fetch collection:', cause);
    error = cause;
  }
}

const structuredData = collection ? {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: collection.title,
  description: collection.description,
  url: new URL(`/collections/${collection.slug}`, Astro.url).toString(),
  mainEntity: {
    '@type': 'ItemList',
    itemListElement: collection.items.map((item, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: item.title,
      url: new URL(`/media/${item.id}`, Astro.url).toString(),
    })),
  },
} : undefined;
---

<BaseLayout
  title={collection?.title ?? 'Collection'}
  description={collection?.description ?? 'A curated Podex collection'}
  structuredData={structuredData}
>
  <main class="py-12 md:py-16">
    <div class="container max-w-5xl">
      {error || !collection ? (
        <StatePanel
          title={error ? 'Unable to load this collection' : 'Collection not found'}
          message={error ? 'This curated collection could not be loaded right now.' : 'This collection is not published or does not exist.'}
          variant={error ? 'error' : 'empty'}
          retryHref="/collections"
        />
      ) : (
        <>
          <header class="mb-12 max-w-3xl">
            <a class="text-sm text-text-secondary hover:text-accent" href="/collections">Back to collections</a>
            <p class="mt-8 font-mono text-xs uppercase tracking-[0.24em] text-accent">Editorial collection</p>
            <h1 class="mt-3 text-4xl text-text">{collection.title}</h1>
            <p class="mt-4 text-lg text-text-secondary">{collection.description}</p>
            <p class="mt-5 text-sm text-text-muted">
              Curated by {collection.curator_name ?? 'Podex Editors'} / {collection.item_count} references
            </p>
          </header>
          {collection.items.length === 0 ? (
            <StatePanel title="This collection is empty" message="References will appear here once selected." />
          ) : (
            <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 md:grid-cols-4">
              {collection.items.map((item) => (
                <MediaCard
                  id={item.id}
                  type={item.type}
                  title={item.title}
                  author={item.author}
                  coverUrl={item.cover_url}
                  mentionCount={item.mention_count}
                  episodeCount={item.episode_count}
                />
              ))}
            </div>
          )}
        </>
      )}
    </div>
  </main>
</BaseLayout>
