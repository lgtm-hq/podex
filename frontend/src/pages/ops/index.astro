---
import BaseLayout from '../../layouts/BaseLayout.astro';
import StatePanel from '../../components/StatePanel.astro';
import {
  getOpsDashboard,
  getOpsOperationalMetrics,
  getOpsOperationalAlerts,
  getOpsPipelineActivity,
  getOpsReviewQueue,
  getOpsScheduledWork,
  getOpsSearchProjection,
} from '../../lib/api';
import type {
  OpsDashboard,
  OpsOperationalMetrics,
  OpsOperationalAlerts,
  OpsPipelineActivity,
  OpsReviewQueue,
  OpsScheduledWork,
  OpsSearchProjection,
} from '../../lib/types';

let dashboard: OpsDashboard | null = null;
let metrics: OpsOperationalMetrics | null = null;
let operationalAlerts: OpsOperationalAlerts | null = null;
let activity: OpsPipelineActivity | null = null;
let reviewQueue: OpsReviewQueue | null = null;
let scheduledWork: OpsScheduledWork | null = null;
let searchProjection: OpsSearchProjection | null = null;
let error: unknown = null;

try {
  [dashboard, metrics, operationalAlerts, activity, reviewQueue, scheduledWork, searchProjection] = await Promise.all([
    getOpsDashboard(),
    getOpsOperationalMetrics(),
    getOpsOperationalAlerts(),
    getOpsPipelineActivity(),
    getOpsReviewQueue(),
    getOpsScheduledWork(),
    getOpsSearchProjection(),
  ]);
} catch (e) {
  error = e;
  console.error('Failed to fetch ops dashboard:', e);
}

const formatNumber = (value: number | undefined): string => (value ?? 0).toLocaleString();
const formatPercent = (part: number, total: number): string => {
  if (total <= 0) {
    return '0%';
  }

  return `${Math.round((part / total) * 100)}%`;
};
const formatStatus = (value: string): string => value.replaceAll('_', ' ');
const formatAge = (seconds?: number | null): string => {
  if (!seconds) {
    return 'None pending';
  }
  if (seconds >= 3600) {
    return `${Math.round(seconds / 3600)}h old`;
  }
  return `${Math.round(seconds / 60)}m old`;
};
const formatDate = (value?: string): string => {
  if (!value) {
    return 'Not scheduled';
  }

  return new Intl.DateTimeFormat('en', {
    month: 'short',
    day: 'numeric',
    hour: '2-digit',
    minute: '2-digit',
  }).format(new Date(value));
};

const statusTone = (status: string): string => {
  const normalized = status.toLowerCase();
  if (['failed', 'error', 'blocked'].includes(normalized)) {
    return 'border-red-500/30 bg-red-500/10 text-red-200';
  }
  if (['pending', 'queued', 'in_progress', 'running'].includes(normalized)) {
    return 'border-amber-500/30 bg-amber-500/10 text-amber-200';
  }
  if (['completed', 'succeeded', 'approved'].includes(normalized)) {
    return 'border-emerald-500/30 bg-emerald-500/10 text-emerald-200';
  }

  return 'border-border bg-surface text-text-secondary';
};

const pipelineIssues = dashboard
  ? dashboard.pipelines.ingestion_runs_failed
    + dashboard.pipelines.transcription_jobs_failed
    + dashboard.pipelines.projection_repairs_failed
  : 0;
const openQueue = reviewQueue?.total ?? 0;
const sourceTotal = dashboard
  ? dashboard.sources.with_rss
    + dashboard.sources.with_spotify
    + dashboard.sources.with_podscripts
    + dashboard.sources.with_youtube
  : 0;
---

<BaseLayout title="Ops Dashboard" description="Operational dashboard for Podex ingestion, review, and search health">
  <main class="min-h-screen bg-background">
    <section class="border-b border-border-subtle bg-surface/30">
      <div class="container py-8 md:py-10">
        <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
          <div>
            <p class="font-mono text-xs uppercase tracking-[0.24em] text-accent">Operations</p>
            <h1 class="mt-3 text-4xl md:text-5xl">Control room</h1>
            <p class="mt-3 max-w-2xl text-text-secondary">
              Pipeline health, review pressure, source coverage, and projection status in one operator view.
            </p>
            <div class="mt-5 flex flex-wrap gap-3">
              <a href="/ops/podcasts" class="btn btn-secondary">Manage podcasts</a>
              <a href="/ops/pipelines" class="btn btn-secondary">Inspect pipelines</a>
              <a href="/ops/review" class="btn btn-secondary">Review candidates</a>
              <a href="/ops/media" class="btn btn-secondary">Canonical media</a>
              <a href="/ops/search" class="btn btn-secondary">Search operations</a>
              <a href="/ops/retention" class="btn btn-secondary">Retention sampling</a>
            </div>
          </div>
          <div class="grid grid-cols-3 gap-3 text-center">
            <div class="rounded-lg border border-border-subtle bg-background px-4 py-3">
              <div class="font-mono text-2xl text-text">{formatNumber(openQueue)}</div>
              <div class="text-xs uppercase tracking-wider text-text-muted">Review</div>
            </div>
            <div class="rounded-lg border border-border-subtle bg-background px-4 py-3">
              <div class="font-mono text-2xl text-text">{formatNumber(pipelineIssues)}</div>
              <div class="text-xs uppercase tracking-wider text-text-muted">Issues</div>
            </div>
            <div class="rounded-lg border border-border-subtle bg-background px-4 py-3">
              <div class="font-mono text-2xl text-text">{searchProjection?.healthy ? 'OK' : 'Watch'}</div>
              <div class="text-xs uppercase tracking-wider text-text-muted">Search</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <div class="container py-8">
      {error ? (
        <StatePanel
          title="Unable to load operations"
          message="Dashboard activity could not be loaded. Confirm the v2 API is available."
          variant="error"
          retryHref="/ops"
        />
      ) : dashboard && metrics && operationalAlerts && activity && reviewQueue && scheduledWork && searchProjection ? (
        <div class="space-y-8">
          {operationalAlerts.alerts.length > 0 && (
            <section class="space-y-3" aria-label="Operational alerts">
              {operationalAlerts.alerts.map((alert) => (
                <div class={`rounded-lg border p-4 ${alert.severity === 'critical' ? 'border-red-500/30 bg-red-500/10' : 'border-amber-500/30 bg-amber-500/10'}`}>
                  <div class="flex flex-wrap items-start justify-between gap-3">
                    <div>
                      <p class="text-sm font-medium uppercase text-text-muted">{alert.severity}</p>
                      <h2 class="mt-1 text-lg">{alert.title}</h2>
                      <p class="mt-1 text-sm text-text-secondary">{alert.message}</p>
                    </div>
                    <p class="font-mono text-sm text-text-secondary">
                      {alert.current_value} / {alert.threshold}
                    </p>
                  </div>
                  <p class="mt-3 text-xs text-text-muted">Playbook: {alert.playbook_slug}</p>
                </div>
              ))}
            </section>
          )}
          <section class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
            <div class="rounded-lg border border-border-subtle bg-surface p-5">
              <div class="text-sm text-text-muted">Active sources</div>
              <div class="mt-2 font-mono text-4xl">{formatNumber(dashboard.catalog.active_podcasts)}</div>
              <div class="mt-3 text-sm text-text-secondary">
                {formatNumber(dashboard.catalog.total_podcasts)} total podcasts, {formatNumber(dashboard.catalog.paused_podcasts)} paused
              </div>
            </div>
            <div class="rounded-lg border border-border-subtle bg-surface p-5">
              <div class="text-sm text-text-muted">Episodes extracted</div>
              <div class="mt-2 font-mono text-4xl">
                {formatPercent(dashboard.episodes.extracted, dashboard.episodes.total_known)}
              </div>
              <div class="mt-3 text-sm text-text-secondary">
                {formatNumber(dashboard.episodes.extracted)} of {formatNumber(dashboard.episodes.total_known)} known episodes
              </div>
            </div>
            <div class="rounded-lg border border-border-subtle bg-surface p-5">
              <div class="text-sm text-text-muted">Pipeline work</div>
              <div class="mt-2 font-mono text-4xl">
                {formatNumber(dashboard.pipelines.ingestion_runs_in_progress + dashboard.pipelines.transcription_jobs_in_progress)}
              </div>
              <div class="mt-3 text-sm text-text-secondary">
                {formatNumber(dashboard.pipelines.transcription_jobs_pending)} pending transcription jobs
              </div>
            </div>
            <div class="rounded-lg border border-border-subtle bg-surface p-5">
              <div class="text-sm text-text-muted">Projection repairs</div>
              <div class="mt-2 font-mono text-4xl">
                {formatNumber(dashboard.pipelines.projection_repairs_pending)}
              </div>
              <div class="mt-3 text-sm text-text-secondary">
                {formatNumber(dashboard.pipelines.projection_repairs_failed)} failed repairs need attention
              </div>
            </div>
          </section>

          <section class="grid gap-4 md:grid-cols-3">
            <div class="rounded-lg border border-border-subtle bg-surface p-5">
              <div class="text-sm text-text-muted">Review throughput / 24h</div>
              <div class="mt-2 font-mono text-4xl">{formatNumber(metrics.review.decisions_last_24h)}</div>
              <div class="mt-3 text-sm text-text-secondary">
                {formatNumber(metrics.review.pending_items)} pending / median {metrics.review.median_decision_minutes_last_24h ?? 0}m
              </div>
            </div>
            <div class="rounded-lg border border-border-subtle bg-surface p-5">
              <div class="text-sm text-text-muted">Projection lag</div>
              <div class="mt-2 font-mono text-4xl">{formatNumber(metrics.projection.pending_repairs)}</div>
              <div class="mt-3 text-sm text-text-secondary">
                Oldest pending: {formatAge(metrics.projection.oldest_pending_age_seconds)}
              </div>
            </div>
            <div class="rounded-lg border border-border-subtle bg-surface p-5">
              <div class="text-sm text-text-muted">Alert delivery / 24h</div>
              <div class="mt-2 font-mono text-4xl">{formatNumber(metrics.alerts.delivered_events_last_24h)}</div>
              <div class="mt-3 text-sm text-text-secondary">
                {formatNumber(metrics.alerts.pending_events)} pending / {formatNumber(metrics.alerts.generated_events_last_24h)} generated
              </div>
            </div>
          </section>

          <section class="grid gap-6 xl:grid-cols-[1.2fr_0.8fr]">
            <div class="rounded-lg border border-border-subtle bg-surface">
              <div class="border-b border-border-subtle p-5">
                <h2 class="text-xl">Pipeline Activity</h2>
                <p class="mt-1 text-sm text-text-muted">Recent ingestion runs and transcription jobs.</p>
              </div>
              <div class="grid gap-0 lg:grid-cols-2">
                <div class="border-b border-border-subtle p-5 lg:border-b-0 lg:border-r">
                  <h3 class="mb-4 text-sm uppercase tracking-wider text-text-muted">Runs</h3>
                  <div class="space-y-3">
                    {activity.runs.length > 0 ? activity.runs.map((run) => (
                      <div class="flex items-start justify-between gap-3 rounded-lg border border-border-subtle bg-background p-3">
                        <div>
                          <div class="font-mono text-xs text-text-muted">{run.id}</div>
                          <div class="mt-1 text-sm text-text-secondary">{formatDate(run.created_at)}</div>
                          {run.error_summary && <div class="mt-2 text-sm text-red-200">{run.error_summary}</div>}
                        </div>
                        <span class={`rounded-full border px-2 py-1 text-xs capitalize ${statusTone(run.status)}`}>
                          {formatStatus(run.status)}
                        </span>
                      </div>
                    )) : (
                      <p class="text-sm text-text-muted">No ingestion runs yet.</p>
                    )}
                  </div>
                </div>
                <div class="p-5">
                  <h3 class="mb-4 text-sm uppercase tracking-wider text-text-muted">Jobs</h3>
                  <div class="space-y-3">
                    {activity.jobs.length > 0 ? activity.jobs.map((job) => (
                      <div class="rounded-lg border border-border-subtle bg-background p-3">
                        <div class="flex items-start justify-between gap-3">
                          <div class="min-w-0">
                            <div class="truncate font-medium">{job.episode_title}</div>
                            <div class="text-sm text-text-muted">{job.podcast_name} · {formatStatus(job.job_type)}</div>
                          </div>
                          <span class={`shrink-0 rounded-full border px-2 py-1 text-xs capitalize ${statusTone(job.status)}`}>
                            {formatStatus(job.status)}
                          </span>
                        </div>
                        {job.error_message && <div class="mt-2 text-sm text-red-200">{job.error_message}</div>}
                      </div>
                    )) : (
                      <p class="text-sm text-text-muted">No transcription jobs yet.</p>
                    )}
                  </div>
                </div>
              </div>
            </div>

            <div class="space-y-6">
              <div class="rounded-lg border border-border-subtle bg-surface p-5">
                <h2 class="text-xl">Provider Coverage</h2>
                <div class="mt-5 space-y-3">
                  {[
                    ['RSS', dashboard.sources.with_rss],
                    ['Spotify', dashboard.sources.with_spotify],
                    ['Podscripts', dashboard.sources.with_podscripts],
                    ['YouTube', dashboard.sources.with_youtube],
                  ].map(([label, value]) => (
                    <div>
                      <div class="mb-1 flex justify-between text-sm">
                        <span>{label}</span>
                        <span class="font-mono text-text-muted">{formatNumber(value as number)}</span>
                      </div>
                      <div class="h-2 overflow-hidden rounded-full bg-background">
                        <div
                          class="h-full rounded-full bg-accent"
                          style={`width: ${sourceTotal > 0 ? ((value as number) / sourceTotal) * 100 : 0}%`}
                        />
                      </div>
                    </div>
                  ))}
                </div>
              </div>

              <div class="rounded-lg border border-border-subtle bg-surface p-5">
                <h2 class="text-xl">Search Projection</h2>
                <div class="mt-4 flex items-center justify-between rounded-lg border border-border-subtle bg-background p-3">
                  <span class="text-sm text-text-secondary">Meilisearch</span>
                  <span class={`rounded-full border px-2 py-1 text-xs ${searchProjection.healthy ? 'border-emerald-500/30 bg-emerald-500/10 text-emerald-200' : 'border-amber-500/30 bg-amber-500/10 text-amber-200'}`}>
                    {searchProjection.configured ? (searchProjection.healthy ? 'Healthy' : 'Degraded') : 'Disabled'}
                  </span>
                </div>
                <div class="mt-4 grid grid-cols-3 gap-3 text-center">
                  <div>
                    <div class="font-mono text-2xl">{formatNumber(searchProjection.repair_summary.pending)}</div>
                    <div class="text-xs text-text-muted">Pending</div>
                  </div>
                  <div>
                    <div class="font-mono text-2xl">{formatNumber(searchProjection.repair_summary.failed)}</div>
                    <div class="text-xs text-text-muted">Failed</div>
                  </div>
                  <div>
                    <div class="font-mono text-2xl">{formatNumber(searchProjection.indexes.length)}</div>
                    <div class="text-xs text-text-muted">Indexes</div>
                  </div>
                </div>
              </div>
            </div>
          </section>

          <section class="grid gap-6 xl:grid-cols-2">
            <div class="rounded-lg border border-border-subtle bg-surface">
              <div class="border-b border-border-subtle p-5">
                <h2 class="text-xl">Review Queue</h2>
                <p class="mt-1 text-sm text-text-muted">{formatNumber(reviewQueue.total)} pending candidates.</p>
              </div>
              <div class="divide-y divide-border-subtle">
                {reviewQueue.items.length > 0 ? reviewQueue.items.map((item) => (
                  <div class="p-5">
                    <div class="flex items-start justify-between gap-3">
                      <div class="min-w-0">
                        <div class="truncate font-medium">{item.candidate.raw_title}</div>
                        <div class="mt-1 text-sm text-text-muted">{item.podcast_name} · {item.episode_title}</div>
                      </div>
                      <span class="rounded-full border border-border bg-background px-2 py-1 text-xs capitalize text-text-secondary">
                        {item.priority}
                      </span>
                    </div>
                    <div class="mt-3 flex items-center gap-3 text-sm text-text-secondary">
                      <span class={`badge badge-${item.candidate.type}`}>{formatStatus(item.candidate.type)}</span>
                      <span>{Math.round(item.candidate.confidence * 100)}% confidence</span>
                    </div>
                  </div>
                )) : (
                  <p class="p-5 text-sm text-text-muted">The review queue is clear.</p>
                )}
              </div>
            </div>

            <div class="rounded-lg border border-border-subtle bg-surface">
              <div class="border-b border-border-subtle p-5">
                <h2 class="text-xl">Scheduled Work</h2>
                <p class="mt-1 text-sm text-text-muted">{formatNumber(scheduledWork.schedules.length)} recurring schedules configured.</p>
              </div>
              <div class="divide-y divide-border-subtle">
                {scheduledWork.work_items.length > 0 ? scheduledWork.work_items.map((item) => (
                  <div class="flex items-start justify-between gap-4 p-5">
                    <div>
                      <div class="font-medium">{formatStatus(item.task_kind)}</div>
                      <div class="mt-1 font-mono text-xs text-text-muted">{item.work_key}</div>
                      <div class="mt-2 text-sm text-text-secondary">Due {formatDate(item.due_at)}</div>
                    </div>
                    <span class={`rounded-full border px-2 py-1 text-xs capitalize ${statusTone(item.status)}`}>
                      {formatStatus(item.status)}
                    </span>
                  </div>
                )) : (
                  <p class="p-5 text-sm text-text-muted">No scheduled work has been planned yet.</p>
                )}
              </div>
            </div>
          </section>
        </div>
      ) : null}
    </div>
  </main>
</BaseLayout>
