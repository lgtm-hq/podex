---
import MediaManager from '../../components/MediaManager';
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Canonical Media" description="Inspect and merge duplicate canonical media records in Podex operations">
  <main class="min-h-screen bg-background">
    <section class="border-b border-border-subtle bg-surface/30">
      <div class="container py-8 md:py-10">
        <div class="flex flex-col gap-5 md:flex-row md:items-end md:justify-between">
          <div>
            <p class="font-mono text-xs uppercase tracking-[0.24em] text-accent">Operations / Media</p>
            <h1 class="mt-3 text-4xl md:text-5xl">Canonical media</h1>
            <p class="mt-3 max-w-2xl text-text-secondary">
              Resolve duplicate records through an inspectable preview of metadata, aliases, and mention movement.
            </p>
          </div>
          <div class="flex flex-wrap gap-3">
            <a href="/ops" class="btn btn-secondary">Dashboard</a>
            <a href="/ops/review" class="btn btn-secondary">Review</a>
          </div>
        </div>
      </div>
    </section>
    <div class="container py-8">
      <MediaManager client:load />
    </div>
  </main>
</BaseLayout>
