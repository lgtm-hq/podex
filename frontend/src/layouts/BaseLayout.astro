---
/**
 * Base Layout
 * Wraps all pages with common structure
 */
import { ClientRouter } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import GlobalSearch from '../components/GlobalSearch';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
  ogType?: 'website' | 'article';
  structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
  title,
  description = 'Discover books, movies, and shows mentioned in podcasts',
  image,
  ogType = 'website',
  structuredData,
} = Astro.props;
const fullTitle = title === 'Podcast Media Index' ? 'Podex - Podcast Media Index' : `${title} | Podex`;
const publicOrigin = (import.meta.env.PUBLIC_WEB_URL || Astro.url.origin).replace(/\/$/, '');
const canonicalUrl = new URL(Astro.url.pathname, `${publicOrigin}/`).toString();
const socialImage = image ? new URL(image, `${publicOrigin}/`).toString() : undefined;
const structuredDataJson = structuredData
  ? JSON.stringify(structuredData).replaceAll('<', '\\u003c')
  : null;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Preload fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <title>{fullTitle}</title>

    <ClientRouter />

    <!-- Theme initialization (prevent flash) -->
    <script is:inline>
      // Default to dark theme (editorial style)
      // Users can toggle to light if preferred
      const theme = localStorage.getItem('podex-theme');
      if (theme === 'light') {
        document.documentElement.classList.add('light');
      }
    </script>

    <!-- Open Graph -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    {socialImage && <meta property="og:image" content={socialImage} />}
    <meta name="twitter:card" content={socialImage ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    {socialImage && <meta name="twitter:image" content={socialImage} />}
    {structuredDataJson && (
      <script is:inline type="application/ld+json" set:html={structuredDataJson} />
    )}
  </head>
  <body class="min-h-screen flex flex-col">
    <GlobalSearch client:load />
    <Header />
    <div class="flex-1">
      <slot />
    </div>
    <Footer />
  </body>
</html>
