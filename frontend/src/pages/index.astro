---
import DegradedBanner from "../components/DegradedBanner";
import EmptyState from "../components/EmptyState";
import PodcastCard from "../components/PodcastCard.astro";
import Layout from "../layouts/Layout.astro";
import { fetchPodcasts } from "../lib/api";
import {
  SITE_DESCRIPTION,
  SITE_NAME,
  SITE_TAGLINE,
  SITE_URL,
} from "../lib/site";
import type { Podcast } from "../lib/types";

let podcasts: Podcast[] = [];
let loadError = false;
try {
  podcasts = await fetchPodcasts();
} catch {
  loadError = true;
}

const websiteJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: SITE_NAME,
  url: `${SITE_URL}/`,
  description: SITE_DESCRIPTION,
  inLanguage: "en",
};

const organisationJsonLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: SITE_NAME,
  url: `${SITE_URL}/`,
};
---

<Layout
  description={SITE_DESCRIPTION}
  canonicalPath="/"
  jsonLd={[websiteJsonLd, organisationJsonLd]}
>
  <section class="mb-12 max-w-2xl">
    <p class="text-xs uppercase tracking-[0.28em] text-[color:var(--color-accent)]">
      Discovery
    </p>
    <h1
      class="font-display mt-3 text-5xl leading-[1.05] font-medium tracking-tight text-[color:var(--color-ink)] sm:text-6xl"
    >
      {SITE_TAGLINE}
    </h1>
    <p class="mt-5 text-lg text-[color:var(--color-muted)]">
      A quiet, curated index of shows and the ideas inside them. Browse the
      catalog below.
    </p>
  </section>

  {
    loadError ? (
      <DegradedBanner />
    ) : podcasts.length === 0 ? (
      <EmptyState title="No podcasts yet." />
    ) : (
      <ul class="grid gap-3">
        {podcasts.map((podcast) => (
          <PodcastCard podcast={podcast} />
        ))}
      </ul>
    )
  }
</Layout>
