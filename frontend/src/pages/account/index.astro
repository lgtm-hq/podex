---
import { AccountHome } from '../../components/AccountHome';
import AccountNavigation from '../../components/AccountNavigation.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Your Account" description="Manage your Podex account">
  <main class="min-h-screen bg-background">
    <section class="border-b border-border-subtle bg-surface/30">
      <div class="container py-10 md:py-14">
        <p class="font-mono text-xs uppercase tracking-[0.24em] text-accent">Account</p>
        <h1 class="mt-3 text-4xl">Your Podex</h1>
        <p class="mt-3 text-text-secondary">A home for the references and sources you want to return to.</p>
      </div>
    </section>
    <AccountNavigation active="overview" />
    <div class="container py-10">
      <div class="max-w-2xl">
        <AccountHome client:load section="overview" />
      </div>
    </div>
  </main>
</BaseLayout>
