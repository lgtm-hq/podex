---
import RetentionSampling from '../../components/RetentionSampling';
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Retention Sampling" description="Manage the permanent transcript calibration corpus in Podex operations">
  <main class="min-h-screen bg-background">
    <section class="border-b border-border-subtle bg-surface/30">
      <div class="container py-8 md:py-10">
        <div class="flex flex-col gap-5 md:flex-row md:items-end md:justify-between">
          <div>
            <p class="font-mono text-xs uppercase tracking-[0.24em] text-accent">Operations / Retention</p>
            <h1 class="mt-3 text-4xl md:text-5xl">Retention sampling</h1>
            <p class="mt-3 max-w-2xl text-text-secondary">
              Govern the permanent calibration corpus retained across source, topic, confidence, and transcript age.
            </p>
          </div>
          <div class="flex flex-wrap gap-3">
            <a href="/ops" class="btn btn-secondary">Dashboard</a>
            <a href="/ops/search" class="btn btn-secondary">Search</a>
          </div>
        </div>
      </div>
    </section>
    <div class="container py-8">
      <RetentionSampling client:load />
    </div>
  </main>
</BaseLayout>
