---
/**
 * ExternalLinks Component
 * Displays external links to IMDB, TMDB, Wikipedia, Google Books, academic sources, etc.
 */
interface Props {
  imdbUrl?: string | null;
  tmdbUrl?: string | null;
  wikipediaUrl?: string | null;
  googleBooksUrl?: string | null;
  openLibraryUrl?: string | null;
  amazonSearchUrl?: string | null;
  // Academic links
  doiUrl?: string | null;
  pubmedUrl?: string | null;
  semanticScholarUrl?: string | null;
}

const {
  imdbUrl,
  tmdbUrl,
  wikipediaUrl,
  googleBooksUrl,
  openLibraryUrl,
  amazonSearchUrl,
  doiUrl,
  pubmedUrl,
  semanticScholarUrl,
} = Astro.props;

const links = [
  { url: imdbUrl, label: 'IMDB', icon: '🎬', color: 'hover:bg-yellow-500/10' },
  { url: tmdbUrl, label: 'TMDB', icon: '🎥', color: 'hover:bg-green-500/10' },
  { url: wikipediaUrl, label: 'Wikipedia', icon: '📖', color: 'hover:bg-gray-500/10' },
  { url: googleBooksUrl, label: 'Google Books', icon: '📚', color: 'hover:bg-blue-500/10' },
  { url: openLibraryUrl, label: 'OpenLibrary', icon: '📕', color: 'hover:bg-orange-500/10' },
  { url: amazonSearchUrl, label: 'Amazon', icon: '🛒', color: 'hover:bg-amber-500/10' },
  // Academic links
  { url: doiUrl, label: 'DOI', icon: '🔗', color: 'hover:bg-teal-500/10' },
  { url: pubmedUrl, label: 'PubMed', icon: '🔬', color: 'hover:bg-red-500/10' },
  { url: semanticScholarUrl, label: 'Semantic Scholar', icon: '📄', color: 'hover:bg-purple-500/10' },
].filter(link => link.url);

const hasLinks = links.length > 0;
---

{hasLinks && (
  <div class="flex flex-wrap gap-2">
    {links.map(link => (
      <a
        href={link.url}
        target="_blank"
        rel="noopener noreferrer"
        class={`inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg border border-border-subtle text-sm text-text-secondary transition-colors ${link.color}`}
      >
        <span>{link.icon}</span>
        <span>{link.label}</span>
        <svg class="w-3 h-3 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
      </a>
    ))}
  </div>
)}
