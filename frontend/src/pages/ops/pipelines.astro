---
import PipelineInspector from '../../components/PipelineInspector';
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Pipeline Runs" description="Inspect and operate Podex pipeline runs and recurring work">
  <main class="min-h-screen bg-background">
    <section class="border-b border-border-subtle bg-surface/30">
      <div class="container py-8 md:py-10">
        <div class="flex flex-col gap-5 md:flex-row md:items-end md:justify-between">
          <div>
            <p class="font-mono text-xs uppercase tracking-[0.24em] text-accent">Operations / Pipelines</p>
            <h1 class="mt-3 text-4xl md:text-5xl">Run inspection</h1>
            <p class="mt-3 max-w-2xl text-text-secondary">
              Trace ingestion work from recurring schedule through run and episode-level stage execution.
            </p>
          </div>
          <div class="flex gap-3">
            <a href="/ops" class="btn btn-secondary">Dashboard</a>
            <a href="/ops/podcasts" class="btn btn-secondary">Podcasts</a>
          </div>
        </div>
      </div>
    </section>
    <div class="container py-8">
      <PipelineInspector client:load />
    </div>
  </main>
</BaseLayout>
