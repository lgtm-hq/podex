---
import type { Podcast } from "../lib/types";

interface Props {
  podcast: Podcast;
}

const { podcast } = Astro.props;
---

<li class="rounded-lg border border-gray-200 p-4">
  <h2 class="font-semibold">{podcast.name}</h2>
  {podcast.description && <p class="text-sm text-gray-600">{podcast.description}</p>}
</li>
