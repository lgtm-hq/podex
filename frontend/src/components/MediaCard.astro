---
/**
 * MediaCard Component
 * Displays a media item (book, movie, TV show, etc.) in a card format
 */
interface Props {
  id: number;
  type: 'book' | 'movie' | 'documentary' | 'tv_show' | 'study' | 'podcast' | 'article' | 'standup_special' | 'person' | 'place';
  title: string;
  author?: string;
  coverUrl?: string;
  mentionCount: number;
  episodeCount: number;
  rating?: number;
  ratingSource?: 'imdb' | 'tmdb' | 'google_books';
}

const { id, type, title, author, coverUrl, mentionCount, episodeCount, rating, ratingSource } = Astro.props;

const typeConfig: Record<string, { icon: string; label: string }> = {
  book: { icon: '📚', label: 'Book' },
  movie: { icon: '🎬', label: 'Movie' },
  documentary: { icon: '🎥', label: 'Documentary' },
  tv_show: { icon: '📺', label: 'TV Show' },
  study: { icon: '🔬', label: 'Study' },
  podcast: { icon: '🎙️', label: 'Podcast' },
  article: { icon: '📰', label: 'Article' },
  standup_special: { icon: '🎤', label: 'Standup' },
  person: { icon: '👤', label: 'Person' },
  place: { icon: '📍', label: 'Place' },
};

// Format rating display
const formatRating = (r: number, source?: string) => {
  if (source === 'google_books') return r.toFixed(1);
  return r.toFixed(1);
};

const config = typeConfig[type] || { icon: '📄', label: type };
---

<a href={`/media/${id}`} class="group block">
  <div class="card overflow-hidden h-full hover-lift">
    <!-- Cover Image -->
    <div class="aspect-[2/3] bg-surface-elevated relative overflow-hidden">
      {coverUrl ? (
        <img
          src={coverUrl}
          alt={title}
          class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
          loading="lazy"
        />
      ) : (
        <div class="w-full h-full flex items-center justify-center text-5xl md:text-6xl bg-gradient-to-br from-surface-elevated to-surface">
          {config.icon}
        </div>
      )}

      <!-- Gradient overlay on hover -->
      <div class="absolute inset-0 bg-gradient-to-t from-background/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>

      <!-- Type Badge -->
      <span class={`absolute top-3 left-3 badge badge-${type}`}>
        {config.label}
      </span>

      <!-- Rating Badge (if available) -->
      {rating && (
        <div class="absolute top-3 right-3 flex items-center gap-1 px-2 py-0.5 rounded-full bg-yellow-500/90 text-black text-xs font-bold">
          <span>⭐</span>
          <span>{formatRating(rating, ratingSource)}</span>
        </div>
      )}

      <!-- Mention count badge -->
      <div class="absolute bottom-3 right-3 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
        <div class="flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-background/90 backdrop-blur-sm text-xs font-medium">
          <svg class="w-3 h-3 text-accent" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M18 10c0 3.866-3.582 7-8 7a8.841 8.841 0 01-4.083-.98L2 17l1.338-3.123C2.493 12.767 2 11.434 2 10c0-3.866 3.582-7 8-7s8 3.134 8 7zM7 9H5v2h2V9zm8 0h-2v2h2V9zM9 9h2v2H9V9z" clip-rule="evenodd" />
          </svg>
          <span>{mentionCount}</span>
        </div>
      </div>
    </div>

    <!-- Info -->
    <div class="p-4">
      <h3 class="font-medium text-text line-clamp-2 group-hover:text-accent transition-colors leading-snug">
        {title}
      </h3>

      {author && (
        <p class="text-sm text-text-muted truncate mt-1.5">{author}</p>
      )}

      <div class="mt-3 pt-3 border-t border-border-subtle flex justify-between text-xs text-text-muted">
        <span class="flex items-center gap-1">
          <span class="font-semibold text-text-secondary">{mentionCount}</span>
          {mentionCount === 1 ? 'mention' : 'mentions'}
        </span>
        <span class="flex items-center gap-1">
          <span class="font-semibold text-text-secondary">{episodeCount}</span>
          {episodeCount === 1 ? 'episode' : 'episodes'}
        </span>
      </div>
    </div>
  </div>
</a>
