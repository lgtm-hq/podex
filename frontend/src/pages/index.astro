---
/**
 * Homepage
 * Dynamic hero with stats and top mentioned media
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import MediaCard from '../components/MediaCard.astro';
import StatePanel from '../components/StatePanel.astro';
import SearchBar from '../components/SearchBar';
import { getOverviewStats, getTopMedia, getPodcasts } from '../lib/api';
import type { OverviewStats, MediaItem, Podcast } from '../lib/types';

let stats: OverviewStats | null = null;
let topMedia: MediaItem[] = [];
let sources: Podcast[] = [];
let degraded = false;

try {
  [stats, topMedia, sources] = await Promise.all([
    getOverviewStats(),
    getTopMedia(8),
    getPodcasts(),
  ]);
} catch (error) {
  degraded = true;
  console.error('Failed to fetch data:', error);
}

// Format large numbers
function formatNumber(num: number): string {
  if (num >= 1000000) return (num / 1000000).toFixed(1) + 'M';
  if (num >= 1000) return (num / 1000).toFixed(1) + 'K';
  return num.toLocaleString();
}

const mediaTypes = [
  { type: 'book', label: 'Books', icon: '📚', color: 'book' },
  { type: 'movie', label: 'Movies', icon: '🎬', color: 'movie' },
  { type: 'tv_show', label: 'TV Shows', icon: '📺', color: 'tv-show' },
  { type: 'documentary', label: 'Docs', icon: '🎥', color: 'documentary' },
  { type: 'podcast', label: 'Podcasts', icon: '🎙️', color: 'podcast' },
  { type: 'standup_special', label: 'Standup', icon: '🎤', color: 'standup' },
];
---

<BaseLayout title="Podcast Media Index">
  <main>
    <!-- Hero Section -->
    <section class="relative min-h-[70vh] flex items-center justify-center overflow-hidden">
      <!-- Background -->
      <div class="absolute inset-0 grid-pattern opacity-50"></div>
      <div class="absolute inset-0 bg-gradient-to-b from-background via-transparent to-background"></div>

      <!-- Content -->
      <div class="container relative z-10 py-20 md:py-32">
        <div class="max-w-4xl mx-auto text-center stagger-children">
          <!-- Tagline -->
          <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-surface border border-border-subtle mb-8">
            <span class="w-2 h-2 rounded-full bg-accent animate-pulse"></span>
            <span class="text-sm text-text-secondary">
              Tracking {stats ? formatNumber(stats.total_mentions) : '...'} media mentions
            </span>
          </div>

          <!-- Main headline -->
          <h1 class="text-display-md md:text-display-lg font-display mb-6">
            Books, movies, and shows<br/>
            <span class="gradient-text">mentioned in podcasts</span>
          </h1>

          <!-- Subtitle -->
          <p class="text-lg md:text-xl text-text-secondary max-w-2xl mx-auto mb-10">
            Discover what podcasters recommend. Search across transcripts and jump directly to the moment it was discussed.
          </p>

          <!-- Search -->
          <div class="max-w-xl mx-auto mb-12">
            <SearchBar client:load placeholder="Search books, movies, TV shows, podcasts..." />
          </div>

          <!-- Quick stats -->
          {stats && (
            <div class="flex flex-wrap justify-center gap-8 md:gap-12">
              <div class="text-center">
                <div class="text-3xl md:text-4xl font-semibold stat-number">{formatNumber(stats.total_media)}</div>
                <div class="stat-label mt-1">References</div>
              </div>
              <div class="text-center">
                <div class="text-3xl md:text-4xl font-semibold stat-number">{formatNumber(stats.total_episodes)}</div>
                <div class="stat-label mt-1">Episodes</div>
              </div>
              <div class="text-center">
                <div class="text-3xl md:text-4xl font-semibold stat-number">{formatNumber(stats.total_mentions)}</div>
                <div class="stat-label mt-1">Mentions</div>
              </div>
              <div class="text-center">
                <div class="text-3xl md:text-4xl font-semibold stat-number">{stats.total_podcasts}</div>
                <div class="stat-label mt-1">Sources</div>
              </div>
            </div>
          )}
        </div>
      </div>
    </section>

    {degraded && (
      <div class="container pb-10">
        <StatePanel
          title="Discovery data is temporarily unavailable"
          message="Search is still available while featured references and source totals reload."
          variant="notice"
          retryHref="/"
        />
      </div>
    )}

    <!-- Browse by Type -->
    <section class="py-16 border-t border-border-subtle">
      <div class="container">
        <div class="flex flex-wrap justify-center gap-3">
          {mediaTypes.map((item) => (
            <a
              href={`/media?type=${item.type}`}
              class="group flex items-center gap-2 px-5 py-3 rounded-xl bg-surface hover:bg-surface-elevated border border-border-subtle hover:border-border transition-all"
            >
              <span class="text-xl">{item.icon}</span>
              <span class="font-medium text-text-secondary group-hover:text-text transition-colors">{item.label}</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Top Mentioned Section -->
    {topMedia.length > 0 && (
      <section class="py-20">
        <div class="container">
          <div class="flex items-end justify-between mb-10">
            <div>
              <h2 class="section-title mb-2">Most Mentioned</h2>
              <p class="section-subtitle">The media that keeps coming up in conversation</p>
            </div>
            <a href="/media?sort=mention_count&order=desc" class="btn btn-ghost hidden md:flex">
              View all
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          </div>

          <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4 md:gap-6 stagger-children">
            {topMedia.map((item) => (
              <MediaCard
                id={item.id}
                type={item.type}
                title={item.title}
                author={item.author}
                coverUrl={item.cover_url}
                mentionCount={item.mention_count}
                episodeCount={item.episode_count}
              />
            ))}
          </div>

          <div class="mt-8 text-center md:hidden">
            <a href="/media?sort=mention_count&order=desc" class="btn btn-secondary">
              View all references
            </a>
          </div>
        </div>
      </section>
    )}

    <!-- Sources Section -->
    {sources.length > 0 && (
      <section class="py-20 bg-surface border-y border-border-subtle">
        <div class="container">
          <div class="text-center mb-12">
            <h2 class="section-title mb-2">Sources</h2>
            <p class="section-subtitle mx-auto">Podcasts we're analyzing for media mentions</p>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-4xl mx-auto">
            {sources.map((podcast) => (
              <a
                href={`/sources/${podcast.slug}`}
                class="card p-6 hover:border-accent/30 group"
              >
                <div class="flex items-start gap-4">
                  {podcast.cover_url ? (
                    <img
                      src={podcast.cover_url}
                      alt={podcast.name}
                      class="w-16 h-16 rounded-lg object-cover"
                    />
                  ) : (
                    <div class="w-16 h-16 rounded-lg bg-surface-elevated flex items-center justify-center text-2xl">
                      🎙️
                    </div>
                  )}
                  <div class="flex-1 min-w-0">
                    <h3 class="font-semibold text-text group-hover:text-accent transition-colors truncate">
                      {podcast.name}
                    </h3>
                    <div class="flex items-center gap-4 mt-2 text-sm text-text-muted">
                      <span>{podcast.episode_count} episodes</span>
                      <span>{podcast.mention_count} mentions</span>
                    </div>
                  </div>
                </div>
              </a>
            ))}
          </div>

          <div class="mt-10 text-center">
            <a href="/sources" class="btn btn-secondary">
              View all sources
            </a>
          </div>
        </div>
      </section>
    )}

    <!-- How it works -->
    <section class="py-20">
      <div class="container">
        <div class="text-center mb-12">
          <h2 class="section-title mb-2">How it works</h2>
          <p class="section-subtitle mx-auto">We use AI to analyze podcast transcripts</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-4xl mx-auto">
          <div class="text-center">
            <div class="w-14 h-14 rounded-2xl bg-accent/10 flex items-center justify-center mx-auto mb-4">
              <span class="text-2xl">🎙️</span>
            </div>
            <h3 class="font-semibold mb-2">1. Transcribe</h3>
            <p class="text-sm text-text-secondary">
              We use Whisper AI to transcribe podcast episodes with high accuracy
            </p>
          </div>

          <div class="text-center">
            <div class="w-14 h-14 rounded-2xl bg-accent/10 flex items-center justify-center mx-auto mb-4">
              <span class="text-2xl">🔍</span>
            </div>
            <h3 class="font-semibold mb-2">2. Extract</h3>
            <p class="text-sm text-text-secondary">
              AI identifies mentions of books, movies, shows, and other media
            </p>
          </div>

          <div class="text-center">
            <div class="w-14 h-14 rounded-2xl bg-accent/10 flex items-center justify-center mx-auto mb-4">
              <span class="text-2xl">🔗</span>
            </div>
            <h3 class="font-semibold mb-2">3. Link</h3>
            <p class="text-sm text-text-secondary">
              Each mention links to the exact timestamp in the original episode
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Fallback for no data -->
    {!stats && (
      <section class="py-20">
        <div class="container">
          <div class="card p-8 max-w-lg mx-auto text-center">
            <div class="w-16 h-16 rounded-2xl bg-surface-elevated flex items-center justify-center mx-auto mb-4">
              <span class="text-3xl">🔌</span>
            </div>
            <h2 class="text-xl font-semibold mb-2">Backend Not Connected</h2>
            <p class="text-text-secondary mb-6">
              Make sure the backend API is running
            </p>
            <div class="text-sm text-left bg-surface-elevated p-4 rounded-lg font-mono">
              <p class="text-text-muted mb-2"># Start the backend</p>
              <p class="text-text">cd backend && make dev-backend</p>
            </div>
          </div>
        </div>
      </section>
    )}
  </main>
</BaseLayout>
