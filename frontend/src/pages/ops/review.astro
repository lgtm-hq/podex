---
import ReviewQueue from '../../components/ReviewQueue';
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Review Queue" description="Review extracted Podex media candidates with evidence and audited decisions">
  <main class="min-h-screen bg-background">
    <section class="border-b border-border-subtle bg-surface/30">
      <div class="container py-8 md:py-10">
        <div class="flex flex-col gap-5 md:flex-row md:items-end md:justify-between">
          <div>
            <p class="font-mono text-xs uppercase tracking-[0.24em] text-accent">Operations / Review</p>
            <h1 class="mt-3 text-4xl md:text-5xl">Quality review</h1>
            <p class="mt-3 max-w-2xl text-text-secondary">
              Inspect extraction evidence and resolve candidates through audited approval, correction, or consolidation.
            </p>
          </div>
          <div class="flex flex-wrap gap-3">
            <a href="/ops" class="btn btn-secondary">Dashboard</a>
            <a href="/ops/pipelines" class="btn btn-secondary">Pipelines</a>
          </div>
        </div>
      </div>
    </section>
    <div class="container py-8">
      <ReviewQueue client:load />
    </div>
  </main>
</BaseLayout>
