# Database URL
# PostgreSQL (recommended for production and scaling):
DATABASE_URL=postgresql://podex:podex@localhost:5432/podex
# SQLite (for quick local testing only):
# DATABASE_URL=sqlite:///./podex.db

# Debug mode
DEBUG=false

# CORS origins (comma-separated)
CORS_ORIGINS=["http://localhost:4321","http://localhost:3000"]

# =============================================================================
# Robust Transcript Scraper Configuration
# =============================================================================

# Rate limiting (seconds)
# SCRAPER_MIN_DELAY=2.0
# SCRAPER_MAX_DELAY=8.0

# Retry attempts per provider
# SCRAPER_MAX_ATTEMPTS=5

# Proxy rotation (comma-separated list of proxy URLs)
# SCRAPER_PROXY_URLS=http://user:pass@proxy1:8080,http://user:pass@proxy2:8080

# Browser cookies for yt-dlp (chrome, firefox, edge, safari, opera, brave)
# SCRAPER_COOKIE_BROWSER=chrome

# Or use a Netscape cookie file instead of browser cookies
# SCRAPER_COOKIE_FILE=/path/to/cookies.txt

# Run Playwright in headed mode for debugging
# SCRAPER_PLAYWRIGHT_HEADED=true

# =============================================================================
# Whisper Transcription Configuration
# =============================================================================

# Backend: faster_whisper (local, free), openai (API), groq (API, fast)
# WHISPER_BACKEND=faster_whisper

# Model size: tiny, base, small, medium, large-v3
# WHISPER_MODEL=base

# Device for local whisper: auto, cpu, cuda
# WHISPER_DEVICE=auto

# Compute type for local whisper: auto, int8, float16, float32
# WHISPER_COMPUTE_TYPE=auto

# API keys for cloud backends
# OPENAI_API_KEY=sk-...
# GROQ_API_KEY=gsk_...

# =============================================================================
# Media Enrichment APIs
# =============================================================================

# TMDB - The Movie Database (free, requires account)
# Get key at: https://www.themoviedb.org/settings/api
# TMDB_API_KEY=...

# OMDB - IMDB data wrapper (free tier: 1000 requests/day)
# Get key at: http://www.omdbapi.com/apikey.aspx
# OMDB_API_KEY=...

# Google Books (optional - works without key but rate limited)
# GOOGLE_BOOKS_API_KEY=...

# =============================================================================
# Meilisearch Configuration
# =============================================================================

# Meilisearch URL (default: http://localhost:7700)
# MEILISEARCH_URL=http://localhost:7700

# Meilisearch master key (required for production)
# MEILISEARCH_MASTER_KEY=your_master_key_here

# Enable/disable Meilisearch integration (default: true)
# MEILISEARCH_ENABLED=true
