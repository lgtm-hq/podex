# Copy to .env.staging and replace every change-me value before deploying.

POSTGRES_USER=podex
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=podex
DATABASE_URL=postgresql://podex:change-me-postgres-password@db:5432/podex

MEILI_MASTER_KEY=change-me-meilisearch-master-key

API_KEY=change-me-podex-api-key
CORS_ORIGINS=["https://staging.podex.example"]
PUBLIC_API_URL=https://staging-api.podex.example/api/v1

BACKEND_PORT=8000
FRONTEND_PORT=4321

RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=100
PUBLIC_SEARCH_RATE_LIMIT_PER_MINUTE=30
AUTH_RATE_LIMIT_PER_MINUTE=10
OPS_RATE_LIMIT_PER_MINUTE=60
ADMIN_RATE_LIMIT_PER_MINUTE=30

MEILISEARCH_ENABLED=true
