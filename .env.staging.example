# .env.staging.example - copy to .env.staging before deploying.
# This file is tracked in git and contains placeholder/default values only.
# Real secrets must never be committed.
#
# Used by: docker compose -f docker-compose.staging.yml --env-file .env.staging
# Loaded into containers via env_file in docker-compose.staging.yml.

# -- Compose and frontend -----------------------------------------------------
# POSTGRES_PASSWORD is read by the db service. PODEX_DATABASE__URL below must
# use the same password in the URL-encoded password segment.
POSTGRES_PASSWORD=change-me-postgres-password
API_PORT=8000
FRONTEND_PORT=4321
# Use the internal Docker service name so Astro SSR fetches stay on the network.
PUBLIC_API_URL=http://api:8000/api/v2

# -- App top-level ------------------------------------------------------------
PODEX_APP_NAME=podex
PODEX_ENVIRONMENT=staging
PODEX_DEBUG=false
PODEX_API_V2_PREFIX=/api/v2
# JSON list; must include the browser origin (scheme + host + port).
PODEX_CORS_ORIGINS=["http://localhost:4321"]
PODEX_PUBLIC_WEB_URL=http://localhost:4321

# -- Database -----------------------------------------------------------------
# URL-encode reserved characters in the password segment only:
#   python -c "from urllib.parse import quote; print(quote('your-password', safe=''))"
PODEX_DATABASE__URL=postgresql://podex:change-me-postgres-password@db:5432/podex
PODEX_DATABASE__POOL_SIZE=5
PODEX_DATABASE__MAX_OVERFLOW=5
PODEX_DATABASE__POOL_RECYCLE_SECONDS=300

# -- Rate limit ---------------------------------------------------------------
PODEX_RATE_LIMIT__ENABLED=true
PODEX_RATE_LIMIT__MAX_REQUESTS=120
PODEX_RATE_LIMIT__WINDOW_SECONDS=60.0
PODEX_RATE_LIMIT__EXEMPT_PATHS=["/health"]
PODEX_RATE_LIMIT__REDIS_URL=
PODEX_RATE_LIMIT__REDIS_PREFIX=podex:ratelimit

# -- Stats cache --------------------------------------------------------------
PODEX_STATS_CACHE__TTL_SECONDS=30.0

# -- Transcripts --------------------------------------------------------------
# Generate a Fernet key with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
PODEX_TRANSCRIPTS__STORAGE_BACKEND=encrypted_s3
PODEX_TRANSCRIPTS__STORAGE_PATH=./data/transcript-artifacts
PODEX_TRANSCRIPTS__ENCRYPTION_KEY=change-me-fernet-key
PODEX_TRANSCRIPTS__S3_BUCKET=change-me-private-transcript-bucket
PODEX_TRANSCRIPTS__S3_ENDPOINT_URL=https://change-me-r2-account.r2.cloudflarestorage.com
PODEX_TRANSCRIPTS__S3_REGION_NAME=auto
PODEX_TRANSCRIPTS__S3_ACCESS_KEY_ID=change-me-r2-access-key-id
PODEX_TRANSCRIPTS__S3_SECRET_ACCESS_KEY=change-me-r2-secret-access-key

# -- Auth ---------------------------------------------------------------------
PODEX_AUTH__MAGIC_LINK_TTL_MINUTES=15
PODEX_AUTH__SESSION_TTL_DAYS=30
PODEX_AUTH__SESSION_COOKIE_NAME=podex_session
PODEX_AUTH__SESSION_COOKIE_SECURE=true
PODEX_AUTH__SMTP_HOST=change-me-smtp-host
PODEX_AUTH__SMTP_PORT=587
PODEX_AUTH__SMTP_USERNAME=change-me-smtp-user
PODEX_AUTH__SMTP_PASSWORD=change-me-smtp-password
PODEX_AUTH__SMTP_FROM_EMAIL=signin@example.com
PODEX_AUTH__SMTP_STARTTLS=true
PODEX_AUTH__WORKOS_CLIENT_ID=
PODEX_AUTH__WORKOS_API_KEY=
PODEX_AUTH__WORKOS_REDIRECT_URI=

# -- Billing ------------------------------------------------------------------
PODEX_BILLING__PAID_TIER_ENABLED=false
PODEX_BILLING__PAID_TIER_ENFORCED=false
PODEX_BILLING__PAID_API_REQUESTS_PER_MONTH=500
PODEX_BILLING__PAID_LLM_REQUESTS_PER_MONTH=25
PODEX_BILLING__PROVIDER_NAME=
PODEX_BILLING__CHECKOUT_URL=
PODEX_BILLING__PADDLE_API_KEY=
PODEX_BILLING__PADDLE_WEBHOOK_SECRET=
PODEX_BILLING__PADDLE_PRICE_ID=
PODEX_BILLING__PADDLE_CHECKOUT_URL=

# -- Observability ------------------------------------------------------------
PODEX_OBSERVABILITY__SENTRY_DSN=
PODEX_OBSERVABILITY__SENTRY_ENVIRONMENT=staging

# -- Enrichment ---------------------------------------------------------------
PODEX_ENRICHMENT__TMDB__ENABLED=true
PODEX_ENRICHMENT__TMDB__BASE_URL=https://api.themoviedb.org/3
PODEX_ENRICHMENT__TMDB__API_KEY=
PODEX_ENRICHMENT__OMDB__ENABLED=true
PODEX_ENRICHMENT__OMDB__BASE_URL=https://www.omdbapi.com
PODEX_ENRICHMENT__OMDB__API_KEY=
PODEX_ENRICHMENT__GOOGLE_BOOKS__ENABLED=true
PODEX_ENRICHMENT__GOOGLE_BOOKS__BASE_URL=https://www.googleapis.com/books/v1
PODEX_ENRICHMENT__GOOGLE_BOOKS__API_KEY=
PODEX_ENRICHMENT__OPEN_LIBRARY__ENABLED=true
PODEX_ENRICHMENT__OPEN_LIBRARY__BASE_URL=https://openlibrary.org
PODEX_ENRICHMENT__ITUNES__ENABLED=true
PODEX_ENRICHMENT__ITUNES__BASE_URL=https://itunes.apple.com
PODEX_ENRICHMENT__WIKIPEDIA__ENABLED=true
PODEX_ENRICHMENT__WIKIPEDIA__BASE_URL=https://en.wikipedia.org/w/api.php
PODEX_ENRICHMENT__PUBMED__ENABLED=true
PODEX_ENRICHMENT__PUBMED__BASE_URL=https://eutils.ncbi.nlm.nih.gov/entrez/eutils
PODEX_ENRICHMENT__PUBMED__API_KEY=
PODEX_ENRICHMENT__SEMANTIC_SCHOLAR__ENABLED=true
PODEX_ENRICHMENT__SEMANTIC_SCHOLAR__BASE_URL=https://api.semanticscholar.org/graph/v1
PODEX_ENRICHMENT__SEMANTIC_SCHOLAR__API_KEY=
PODEX_ENRICHMENT__CROSSREF__ENABLED=true
PODEX_ENRICHMENT__CROSSREF__BASE_URL=https://api.crossref.org
PODEX_ENRICHMENT__CROSSREF__MAILTO=

# -- Ops top-level ------------------------------------------------------------
PODEX_OPS_API_KEY=
PODEX_OPS_REVIEW_PENDING_ALERT_THRESHOLD=50
PODEX_OPS_ALERT_DELIVERY_PENDING_THRESHOLD=25

# -- Scheduler top-level ------------------------------------------------------
PODEX_SCHEDULER_TICK_SECONDS=60
PODEX_SCHEDULER_DIGEST_INTERVAL_MINUTES=1440
PODEX_SCHEDULER_RETENTION_INTERVAL_MINUTES=1440
