{
  "components": {
    "schemas": {
      "CatalogStats": {
        "description": "Top-level catalog counters plus a small top-list breakdown.\n\nAttributes:\n    podcasts: Total podcast sources in the catalog.\n    episodes: Total episodes across all sources.\n    media: Total canonical media items in the catalog. Counts every\n        ``Media`` row, not just those referenced by a mention.\n    mentions: Total episode<->media mention links.\n    top_media_types: Up to five media types ordered by descending count,\n        with ties broken alphabetically by type name for stability.",
        "properties": {
          "episodes": {
            "minimum": 0.0,
            "title": "Episodes",
            "type": "integer"
          },
          "media": {
            "description": "Total canonical media items in the catalog (every Media row).",
            "minimum": 0.0,
            "title": "Media",
            "type": "integer"
          },
          "mentions": {
            "minimum": 0.0,
            "title": "Mentions",
            "type": "integer"
          },
          "podcasts": {
            "minimum": 0.0,
            "title": "Podcasts",
            "type": "integer"
          },
          "top_media_types": {
            "description": "Up to five media types ordered by descending count; ties broken alphabetically by type name.",
            "items": {
              "$ref": "#/components/schemas/MediaTypeCount"
            },
            "maxItems": 5,
            "title": "Top Media Types",
            "type": "array"
          }
        },
        "required": [
          "podcasts",
          "episodes",
          "media",
          "mentions",
          "top_media_types"
        ],
        "title": "CatalogStats",
        "type": "object"
      },
      "EpisodeRead": {
        "description": "Public representation of a podcast episode.",
        "properties": {
          "created_at": {
            "format": "date-time",
            "title": "Created At",
            "type": "string"
          },
          "episode_number": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Episode Number"
          },
          "id": {
            "title": "Id",
            "type": "integer"
          },
          "podcast_id": {
            "title": "Podcast Id",
            "type": "integer"
          },
          "published_at": {
            "anyOf": [
              {
                "format": "date-time",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Published At"
          },
          "title": {
            "title": "Title",
            "type": "string"
          }
        },
        "required": [
          "id",
          "podcast_id",
          "title",
          "episode_number",
          "published_at",
          "created_at"
        ],
        "title": "EpisodeRead",
        "type": "object"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "MediaRead": {
        "description": "Public representation of a canonical media item.",
        "properties": {
          "author": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Author"
          },
          "cover_url": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Cover Url"
          },
          "created_at": {
            "format": "date-time",
            "title": "Created At",
            "type": "string"
          },
          "description": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Description"
          },
          "id": {
            "title": "Id",
            "type": "integer"
          },
          "title": {
            "title": "Title",
            "type": "string"
          },
          "type": {
            "$ref": "#/components/schemas/MediaType"
          },
          "year": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Year"
          }
        },
        "required": [
          "id",
          "type",
          "title",
          "author",
          "year",
          "description",
          "cover_url",
          "created_at"
        ],
        "title": "MediaRead",
        "type": "object"
      },
      "MediaType": {
        "description": "The kind of media a catalog item represents.",
        "enum": [
          "book",
          "movie",
          "documentary",
          "tv_show",
          "study",
          "podcast",
          "article",
          "person",
          "place"
        ],
        "title": "MediaType",
        "type": "string"
      },
      "MediaTypeCount": {
        "description": "One row of the ``top_media_types`` breakdown.",
        "properties": {
          "count": {
            "description": "Number of media rows of this type.",
            "minimum": 0.0,
            "title": "Count",
            "type": "integer"
          },
          "media_type": {
            "description": "MediaType value (e.g. ``book``, ``movie``).",
            "title": "Media Type",
            "type": "string"
          }
        },
        "required": [
          "media_type",
          "count"
        ],
        "title": "MediaTypeCount",
        "type": "object"
      },
      "MentionRead": {
        "description": "Public representation of a media mention within an episode.",
        "properties": {
          "confidence": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Confidence"
          },
          "context": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Context"
          },
          "created_at": {
            "format": "date-time",
            "title": "Created At",
            "type": "string"
          },
          "episode_id": {
            "title": "Episode Id",
            "type": "integer"
          },
          "id": {
            "title": "Id",
            "type": "integer"
          },
          "media_id": {
            "title": "Media Id",
            "type": "integer"
          },
          "timestamp_seconds": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Timestamp Seconds"
          }
        },
        "required": [
          "id",
          "episode_id",
          "media_id",
          "timestamp_seconds",
          "context",
          "confidence",
          "created_at"
        ],
        "title": "MentionRead",
        "type": "object"
      },
      "PodcastRead": {
        "description": "Public representation of a podcast source.",
        "properties": {
          "created_at": {
            "format": "date-time",
            "title": "Created At",
            "type": "string"
          },
          "description": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Description"
          },
          "id": {
            "title": "Id",
            "type": "integer"
          },
          "name": {
            "title": "Name",
            "type": "string"
          },
          "slug": {
            "title": "Slug",
            "type": "string"
          }
        },
        "required": [
          "id",
          "name",
          "slug",
          "description",
          "created_at"
        ],
        "title": "PodcastRead",
        "type": "object"
      },
      "ValidationError": {
        "properties": {
          "ctx": {
            "title": "Context",
            "type": "object"
          },
          "input": {
            "title": "Input"
          },
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      }
    }
  },
  "info": {
    "title": "podex",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/api/v2/episodes": {
      "get": {
        "description": "List episodes, optionally filtered by podcast.",
        "operationId": "list_episodes_api_v2_episodes_get",
        "parameters": [
          {
            "in": "query",
            "name": "podcast_id",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "integer"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Podcast Id"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/EpisodeRead"
                  },
                  "title": "Response List Episodes Api V2 Episodes Get",
                  "type": "array"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "List Episodes",
        "tags": [
          "v2",
          "episodes"
        ]
      }
    },
