---
import BaseLayout from '../../layouts/BaseLayout.astro';
import StatePanel from '../../components/StatePanel.astro';
import { getEpisode, getEpisodeMentions } from '../../lib/api';
import type { EpisodeDetail, MediaType, MentionWithMedia } from '../../lib/types';

const { id } = Astro.params;
const episodeId = id as string;

let episode: EpisodeDetail | null = null;
let mentions: MentionWithMedia[] = [];
let error: unknown = null;

try {
  [episode, mentions] = await Promise.all([
    getEpisode(episodeId),
    getEpisodeMentions(episodeId),
  ]);
} catch (e) {
  error = e;
  console.error('Failed to fetch episode:', e);
}

if (!episode && !error) {
  return Astro.redirect('/404');
}

const formattedDate = episode?.published_at
  ? new Date(episode.published_at).toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : null;

function formatDuration(seconds: number): string {
  const hours = Math.floor(seconds / 3600);
  const minutes = Math.floor((seconds % 3600) / 60);
  if (hours > 0) {
    return `${hours}h ${minutes}m`;
  }
  return `${minutes}m`;
}

function formatTimestamp(seconds: number): string {
  const hours = Math.floor(seconds / 3600);
  const minutes = Math.floor((seconds % 3600) / 60);
  const secs = seconds % 60;
  if (hours > 0) {
    return `${hours}:${minutes.toString().padStart(2, '0')}:${secs.toString().padStart(2, '0')}`;
  }
  return `${minutes}:${secs.toString().padStart(2, '0')}`;
}

// Group mentions by media
interface EpisodeMentionGroup {
  id: string;
  title: string;
  type: MediaType;
  author: string | null;
  mentions: MentionWithMedia[];
}

const uniqueMedia = new Map<string, EpisodeMentionGroup>();
mentions.forEach((mention) => {
  if (!uniqueMedia.has(mention.media_id)) {
    uniqueMedia.set(mention.media_id, {
      id: mention.media_id,
      title: mention.media_title,
      type: mention.media_type,
      author: mention.media_author ?? null,
      mentions: [],
    });
  }
  uniqueMedia.get(mention.media_id)?.mentions.push(mention);
});
const mediaList = Array.from(uniqueMedia.values());
const structuredData = episode ? {
  '@context': 'https://schema.org',
  '@type': 'PodcastEpisode',
  name: episode.title,
  datePublished: episode.published_at,
  duration: episode.duration_seconds ? `PT${episode.duration_seconds}S` : undefined,
  partOfSeries: {
    '@type': 'PodcastSeries',
    name: episode.podcast_name,
    url: new URL(`/sources/${episode.podcast_slug}`, Astro.url).toString(),
  },
  url: new URL(`/episodes/${episode.id}`, Astro.url).toString(),
} : undefined;
---

<BaseLayout
  title={episode?.title || 'Episode'}
  description={episode?.derivative_summary ?? 'A podcast episode with traced reference mentions'}
  image={episode?.thumbnail_url}
  ogType="article"
  structuredData={structuredData}
>
  <div class="container mx-auto px-4 py-8">
    {error ? (
      <StatePanel
        title="Unable to load this episode"
        message="This episode could not be retrieved right now."
        variant="error"
        retryHref={`/episodes/${episodeId}`}
      />
    ) : episode && (
      <>
        <!-- Episode Header -->
        <div class="flex flex-col md:flex-row gap-8 mb-12">
          <!-- Thumbnail -->
          {episode.thumbnail_url && (
            <div class="w-full md:w-80 flex-shrink-0">
              <img
                src={episode.thumbnail_url}
                alt={episode.title}
                class="w-full rounded-lg shadow-lg"
              />
            </div>
          )}

          <!-- Info -->
          <div class="flex-1">
            {episode.episode_number && (
              <span class="text-sm font-medium text-primary mb-2 block">
                Episode #{episode.episode_number}
              </span>
            )}
            <h1 class="text-3xl md:text-4xl font-bold mb-4">{episode.title}</h1>

            <div class="flex flex-wrap gap-4 text-text-muted mb-6">
              {formattedDate && (
                <span class="flex items-center gap-2">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                  </svg>
                  {formattedDate}
                </span>
              )}
              {episode.duration_seconds && (
                <span class="flex items-center gap-2">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  {formatDuration(episode.duration_seconds)}
                </span>
              )}
            </div>

            {/* Stats */}
            <div class="flex gap-6 mb-6">
              <div>
                <p class="text-2xl font-bold text-primary">{mentions.length}</p>
                <p class="text-sm text-text-muted">media mentions</p>
              </div>
              <div>
                <p class="text-2xl font-bold text-text">{mediaList.length}</p>
                <p class="text-sm text-text-muted">unique items</p>
              </div>
            </div>

            {/* YouTube Link */}
            {episode.youtube_id && (
              <a
                href={`https://youtube.com/watch?v=${episode.youtube_id}`}
                target="_blank"
                rel="noopener noreferrer"
                class="btn btn-primary inline-flex items-center gap-2"
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
                </svg>
                Watch on YouTube
              </a>
            )}
          </div>
        </div>

        {(episode.derivative_summary || episode.derivative_mentioned_media_titles.length > 0) && (
          <section class="mb-12 max-w-3xl">
            <p class="text-sm font-medium text-primary mb-2">Episode overview</p>
            {episode.derivative_summary && (
              <p class="text-lg leading-relaxed text-text-secondary mb-4">
                {episode.derivative_summary}
              </p>
            )}
            {episode.derivative_mentioned_media_titles.length > 0 && (
              <p class="text-sm text-text-muted">
                References identified in this episode: {episode.derivative_mentioned_media_titles.join(', ')}.
              </p>
            )}
          </section>
        )}

        <!-- Media Mentioned -->
        <div>
          <h2 class="text-2xl font-bold mb-6">
            Media Mentioned ({mediaList.length})
          </h2>
          <p class="text-sm text-text-muted mb-6">
            Each reference below is tied to a captured mention and, when available, a timestamped source moment.
          </p>

          {mediaList.length > 0 ? (
            <div class="space-y-6">
              {mediaList.map((media) => (
                <div class="card p-4">
                  <div class="flex items-start gap-4">
                    <a href={`/media/${media.id}`} class="flex-shrink-0">
                      <div class="w-16 h-24 bg-surface rounded flex items-center justify-center text-3xl">
                        {media.type === 'book' ? '📚' : media.type === 'movie' ? '🎬' : '🎥'}
                      </div>
                    </a>
                    <div class="flex-1">
                      <a href={`/media/${media.id}`} class="font-semibold text-text hover:text-primary">
                        {media.title}
                      </a>
                      {media.author && (
                        <p class="text-sm text-text-muted">by {media.author}</p>
                      )}
                      <div class="mt-2 flex flex-col gap-2">
                        {media.mentions.map((mention) => (
                          <div class="flex flex-col gap-1">
                            {mention.timestamp_seconds != null && mention.youtube_timestamp_url ? (
                              <a
                                href={mention.youtube_timestamp_url}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="inline-flex items-center gap-1 px-2 py-1 bg-primary/10 text-primary text-xs rounded hover:bg-primary/20 w-fit"
                              >
                                <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24">
                                  <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
                                </svg>
                                {formatTimestamp(mention.timestamp_seconds)}
                              </a>
                            ) : mention.timestamp_seconds != null && (
                              <span class="inline-flex items-center px-2 py-1 bg-surface text-text-muted text-xs rounded w-fit">
                                at {formatTimestamp(mention.timestamp_seconds)}
                              </span>
                            )}
                            {mention.context && (
                              <p class="text-xs text-text-muted italic">
                                "{mention.context}"
                              </p>
                            )}
                          </div>
                        ))}
                      </div>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          ) : (
            <p class="text-text-muted">No media mentions recorded for this episode.</p>
          )}
        </div>

        <!-- Back Link -->
        <div class="mt-8">
          <a href="/episodes" class="text-primary hover:underline">
            ← Back to all episodes
          </a>
        </div>
      </>
    )}
  </div>
</BaseLayout>
