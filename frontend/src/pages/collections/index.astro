---
import StatePanel from '../../components/StatePanel.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollections } from '../../lib/api';
import type { EditorialCollectionSummary } from '../../lib/types';

let collections: EditorialCollectionSummary[] = [];
let error: unknown = null;

try {
  collections = await getCollections();
} catch (cause) {
  console.error('Failed to fetch collections:', cause);
  error = cause;
}
---

<BaseLayout title="Collections" description="Curated Podex collections of podcast-recommended references">
  <main class="py-12 md:py-16">
    <div class="container max-w-5xl">
      <header class="mb-12 max-w-2xl">
        <p class="font-mono text-xs uppercase tracking-[0.24em] text-accent">Editorial</p>
        <h1 class="mt-3 text-4xl text-text">Collections</h1>
        <p class="mt-3 text-lg text-text-secondary">
          Curated trails through the references that surface across podcast conversations.
        </p>
      </header>
      {error ? (
        <StatePanel
          title="Unable to load collections"
          message="Curated collections could not be loaded right now."
          variant="error"
          retryHref="/collections"
        />
      ) : collections.length === 0 ? (
        <StatePanel
          title="No published collections yet"
          message="Curated discovery trails will appear here as they are published."
        />
      ) : (
        <div class="grid gap-5 md:grid-cols-2">
          {collections.map((collection) => (
            <a class="rounded-lg border border-border-subtle bg-surface p-6 transition-colors hover:border-accent/40" href={`/collections/${collection.slug}`}>
              {collection.featured && <p class="mb-3 text-xs uppercase text-accent">Featured</p>}
              <h2 class="text-2xl text-text">{collection.title}</h2>
              <p class="mt-3 line-clamp-3 text-text-secondary">{collection.description}</p>
              <div class="mt-6 flex justify-between text-sm text-text-muted">
                <span>{collection.curator_name ?? 'Podex Editors'}</span>
                <span>{collection.item_count} references</span>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </main>
</BaseLayout>
