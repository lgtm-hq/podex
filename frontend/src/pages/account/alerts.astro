---
import AccountNavigation from '../../components/AccountNavigation.astro';
import { AccountHome } from '../../components/AccountHome';
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Alerts" description="Manage your Podex alerts and digest delivery">
  <main class="min-h-screen bg-background">
    <section class="border-b border-border-subtle bg-surface/30">
      <div class="container py-10 md:py-14">
        <p class="font-mono text-xs uppercase tracking-[0.24em] text-accent">Account</p>
        <h1 class="mt-3 text-4xl">Alerts and digests</h1>
        <p class="mt-3 text-text-secondary">Decide what activity reaches you and see delivery history.</p>
      </div>
    </section>
    <AccountNavigation active="alerts" />
    <div class="container py-10">
      <div class="max-w-2xl">
        <AccountHome client:load section="alerts" />
      </div>
    </div>
  </main>
</BaseLayout>
