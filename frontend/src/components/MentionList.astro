---
import type { MentionWithEpisode } from '../lib/types';

interface Props {
  mentions: MentionWithEpisode[];
}

const { mentions } = Astro.props;

function formatTimestamp(seconds: number): string {
  const hours = Math.floor(seconds / 3600);
  const minutes = Math.floor((seconds % 3600) / 60);
  const secs = seconds % 60;

  if (hours > 0) {
    return `${hours}:${minutes.toString().padStart(2, '0')}:${secs.toString().padStart(2, '0')}`;
  }
  return `${minutes}:${secs.toString().padStart(2, '0')}`;
}
---

<div class="space-y-4">
  {mentions.map((mention) => (
    <div class="card p-4">
      <div class="flex items-start gap-4">
        <!-- Episode thumbnail -->
        {mention.episode.thumbnail_url && (
          <a href={`/episodes/${mention.episode.id}`} class="flex-shrink-0">
            <img
              src={mention.episode.thumbnail_url}
              alt={mention.episode.title}
              class="w-24 h-14 object-cover rounded"
              loading="lazy"
            />
          </a>
        )}

        <div class="flex-1 min-w-0">
          <!-- Episode info -->
          <a href={`/episodes/${mention.episode.id}`} class="font-medium text-text hover:text-primary">
            {mention.episode.title}
          </a>

          <!-- Timestamp & YouTube link -->
          {mention.timestamp_seconds != null && (
            <div class="mt-1">
              {mention.youtube_timestamp_url ? (
                <a
                  href={mention.youtube_timestamp_url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-1 text-sm text-primary hover:text-primary/80"
                >
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
                  </svg>
                  Watch at {formatTimestamp(mention.timestamp_seconds)}
                </a>
              ) : (
                <span class="text-sm text-text-muted">
                  at {formatTimestamp(mention.timestamp_seconds)}
                </span>
              )}
            </div>
          )}

          <!-- Context quote -->
          {mention.context && (
            <blockquote class="mt-2 text-sm text-text-muted italic border-l-2 border-border pl-3">
              "{mention.context}"
            </blockquote>
          )}
        </div>
      </div>
    </div>
  ))}
</div>
