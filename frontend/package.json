{
  "name": "podex-frontend",
  "type": "module",
  "version": "0.6.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "generate:api": "openapi-typescript ./openapi.json -o ./src/lib/types.gen.ts",
    "check:api": "bun run generate:api && git diff --exit-code -- src/lib/types.gen.ts",
    "check": "astro check && bun run check:api",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/node": "^11.0.0",
    "@astrojs/react": "^6.0.0",
    "@sentry/browser": "^10.66.0",
    "@tailwindcss/vite": "^4.0.0",
    "astro": "^7.1.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.0.0",
    "typescript": "6.0.3"
  },
  "devDependencies": {
    "@testing-library/react": "16.3.2",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-v8": "4.1.10",
    "happy-dom": "20.10.6",
    "openapi-typescript": "7.13.0",
    "vitest": "4.1.10"
  },
  "overrides": {
    "js-yaml": "4.3.0"
  }
}
