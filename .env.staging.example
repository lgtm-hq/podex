# Copy to .env.staging and replace every change-me value before deploying.

POSTGRES_USER=podex
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=podex
DATABASE_URL=postgresql://podex:change-me-postgres-password@db:5432/podex
TRANSCRIPT_ARTIFACT_STORAGE_BACKEND=encrypted_s3
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TRANSCRIPT_ARTIFACT_ENCRYPTION_KEY=change-me-fernet-key
TRANSCRIPT_ARTIFACT_S3_BUCKET=change-me-private-transcript-bucket
TRANSCRIPT_ARTIFACT_S3_REGION_NAME=eu-west-1
# Set for S3-compatible storage such as MinIO; leave empty for AWS S3.
TRANSCRIPT_ARTIFACT_S3_ENDPOINT_URL=
# Leave empty to use the host/workload AWS credential provider chain.
TRANSCRIPT_ARTIFACT_S3_ACCESS_KEY_ID=
TRANSCRIPT_ARTIFACT_S3_SECRET_ACCESS_KEY=

MEILI_MASTER_KEY=change-me-meilisearch-master-key

API_KEY=change-me-podex-api-key
CORS_ORIGINS=["https://staging.podex.example"]
PUBLIC_API_URL=https://staging-api.podex.example/api/v2
PUBLIC_WEB_URL=https://staging.podex.example
AUTH_MAGIC_LINK_TTL_MINUTES=15
AUTH_SESSION_TTL_DAYS=30
AUTH_SESSION_COOKIE_NAME=podex_session
AUTH_SESSION_COOKIE_SECURE=true
SMTP_HOST=change-me-smtp-host
SMTP_PORT=587
SMTP_USERNAME=change-me-smtp-user
SMTP_PASSWORD=change-me-smtp-password
SMTP_FROM_EMAIL=sign-in@staging.podex.example
SMTP_STARTTLS=true
PAID_TIER_ENABLED=false
PAID_TIER_ENFORCED=false
PAID_API_REQUESTS_PER_MONTH=500
PAID_LLM_REQUESTS_PER_MONTH=25
BILLING_PROVIDER_NAME=
BILLING_CHECKOUT_URL=
OPS_REVIEW_PENDING_ALERT_THRESHOLD=50
OPS_PROJECTION_PENDING_ALERT_THRESHOLD=25
OPS_PROJECTION_OLDEST_PENDING_MINUTES=60
OPS_ALERT_DELIVERY_PENDING_THRESHOLD=25

BACKEND_PORT=8000
FRONTEND_PORT=4321

RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=100
PUBLIC_SEARCH_RATE_LIMIT_PER_MINUTE=30
AUTH_RATE_LIMIT_PER_MINUTE=10
OPS_RATE_LIMIT_PER_MINUTE=60
ADMIN_RATE_LIMIT_PER_MINUTE=30

MEILISEARCH_ENABLED=true
